APP_NAME="AI Document Intelligence System"
APP_VERSION="0.1.0"
DATABASE_URL="sqlite:///./dev.db"
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_BYTES="10485760"

EMBEDDING_PROVIDER="local"
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
VECTOR_STORE_PROVIDER="database"
CHROMA_PERSIST_DIR="chromadb"
CHUNK_SIZE_WORDS="180"
CHUNK_OVERLAP_WORDS="30"
CHAT_RETRIEVAL_LIMIT="4"

CLASSIFIER_PROVIDER="local"
SUMMARY_SENTENCE_COUNT="2"

JWT_SECRET_KEY="change-this-secret-key-for-local-development-only"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"
